# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase runtime (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY

# Optional: automatic admin role assignment on first Google OAuth login
ADMIN_EMAIL_ALLOWLIST=you@example.com,comite@pe.uwc.org

# Optional: temporary dev bypass while OAuth is being configured
NEXT_PUBLIC_ENABLE_DEV_BYPASS=false
# Optional: deployment hint used to keep demo bypass hidden in production
NEXT_PUBLIC_VERCEL_ENV=development
NEXT_PUBLIC_DEMO_ADMIN_EMAIL=admin.demo@uwcperu.org
NEXT_PUBLIC_DEMO_APPLICANT_EMAIL=applicant.demo@uwcperu.org
NEXT_PUBLIC_DEMO_APPLICANT_2_EMAIL=applicant.demo2@uwcperu.org
NEXT_PUBLIC_DEMO_APPLICANT_3_EMAIL=applicant.demo3@uwcperu.org
NEXT_PUBLIC_DEMO_PASSWORD=ChangeMe123!

# Supabase secret key (required for seeding fake users script)
SUPABASE_SECRET_KEY=

# OCR (optional)
GEMINI_API_KEY=

# Email delivery (configure Gmail API for real send)
GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REFRESH_TOKEN=
GOOGLE_GMAIL_SENDER_EMAIL=
GOOGLE_GMAIL_REDIRECT_URI=http://localhost:3000/auth/google-mail/callback
EMAIL_FROM_NAME="UWC Peru"
EMAIL_REPLY_TO=

# Logging
LOG_LEVEL=info
